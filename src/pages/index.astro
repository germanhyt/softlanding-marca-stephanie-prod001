---
import MainLayout from "@/layouts/MainLayout.astro";
import HeroSection from "@/components/sections/HeroSection";
import ConsultoriaSection from "@/components/sections/ConsultoriaSection";
import ServiciosSection from "@/components/sections/ServiciosSection";
import ProcesoSection from "@/components/sections/ProcesoSection";
import SobreMiSection from "@/components/sections/SobreMiSection";
import NewsletterSection from "@/components/sections/NewsletterSection";
import FooterSection from "@/components/sections/FooterSection";
---

<MainLayout>
  <HeroSection client:load />
  <main>
    <ConsultoriaSection client:visible />
    <ServiciosSection client:visible />
    <ProcesoSection client:visible />
    <SobreMiSection client:visible />
    <NewsletterSection client:visible />
  </main>
  <FooterSection client:visible />
</MainLayout>
